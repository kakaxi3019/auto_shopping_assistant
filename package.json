{
  "name": "auto-shopping",
  "version": "1.0.0",
  "description": "自动购物助手 - 周期性复购自动化桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "chcp 65001 >nul 2>&1 & vite",
    "build": "vite build && electron-builder --win zip",
    "build:dir": "vite build && electron-builder --dir",
    "build:nsis": "vite build && electron-builder --win nsis",
    "start": "electron dist-electron/main.js"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "openai": "^4.90.0",
    "playwright": "^1.52.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.5",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.5.0",
    "electron": "^35.5.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.14",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.autoshopping.app",
    "productName": "自动购物助手",
    "directories": {
      "buildResources": "build",
      "output": "release-dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/",
        "to": "sql.js/",
        "filter": [
          "*.wasm"
        ]
      },
      {
        "from": "extra/playwright-browsers/",
        "to": "playwright-browsers/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/auto_shopping_app_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
